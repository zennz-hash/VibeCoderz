    "@react-oauth/google": "^0.13.4",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
