{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx prisma generate && tsx server.ts",
    "start": "npx prisma generate && npx prisma db push && tsx server.ts",
    "build": "npx prisma generate && vite build",
    "vercel-build": "npx prisma generate && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "npx prisma generate && tsc --noEmit",
    "test": "npx prisma generate && node --import dotenv/config --import tsx --test server/routes/quota.test.ts server/routes/codeProjects.test.ts server/utils/aiModels.test.ts server/utils/validation.test.ts",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push"
  },
