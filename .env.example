# ─── AI Provider ───
# 9router adalah provider utama OpenAI-compatible untuk PRD Thinking, PRD Revision, dan Build Code.
ROUTER9_API_KEY=""
ROUTER9_BASE_URL="https://your-9router-openai-compatible-base-url/v1"
ROUTER9_MODEL="ag/gemini-3-flash"

# ─── Auth (WAJIB) ───
# Secret JWT minimal 32 karakter. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""
# Comma-separated. Email ini otomatis dipromosikan menjadi ADMIN saat login Google.
ADMIN_EMAILS="ikhwanda466@gmail.com"

# ─── Google OAuth ───
VITE_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# ─── Database (SQLite lokal / Turso cloud) ───
SQLITE_URL="file:./dev.db"
# Untuk deploy ke Vercel, gunakan Turso (cloud SQLite gratis):
# TURSO_DATABASE_URL="libsql://your-db-name-your-username.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── Opsional ───
# PORT=3000
# NODE_ENV=development
# FRONTEND_URL="https://your-domain.com"  # wajib diset di produksi bila frontend beda origin; boleh comma-separated
# VITE_API_URL="https://api.your-domain.com" # isi bila frontend tidak disajikan dari server/API yang sama
# TRUST_PROXY="1"          # aktifkan hanya jika berada di belakang reverse proxy terpercaya
# LOG_RETENTION_DAYS="90"  # set 0 untuk menonaktifkan cleanup otomatis log audit/AI
# AUTH_COOKIE_SAMESITE="none" # gunakan hanya untuk frontend/backend beda site via HTTPS
# CROSS_SITE_COOKIES="true"   # alternatif boolean untuk mengaktifkan SameSite=None; Secure
