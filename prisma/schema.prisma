generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("SQLITE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  picture   String?
  googleId  String?  @unique
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blueprints    Blueprint[]
  subscriptions PlanSubscription[]
  usageLogs     UsageLog[]
  sessions      AuthSession[]
  auditLogs     AuditLog[]
  aiRequestLogs AiRequestLog[]
  codeProjects  CodeProject[]
}

model AuthSession {
  id        String    @id @default(uuid())
  userId    String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PlanSubscription {
  id                 String    @id @default(uuid())
  userId             String
  planType           String    @default("FREE") // FREE, PRO, PRO_MAX
  status             String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  prdQuota           Int       @default(1) // Max PRDs per day for this plan
  quotaUsedToday     Int       @default(0) // How many PRDs used today
  codeQuotaUsedToday Int       @default(0) // How many Code generations used today
  lastQuotaReset     DateTime  @default(now()) // When quota was last reset (daily)
  activeUntil        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([activeUntil])
}

model Blueprint {
  id             String    @id @default(uuid())
  userId         String
  name           String
  type           String
  content        String
  isPublic       Boolean   @default(false)
  shareToken     String?   @unique
  shareExpiresAt DateTime?
  shareViewCount Int       @default(0)
  folder         String?
  tagsJson       String    @default("[]")
  currentVersion Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions BlueprintVersion[]

  @@index([userId, createdAt])
  @@index([shareToken])
  @@index([shareExpiresAt])
  @@index([userId, folder])
}

model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  type      String // PRD_GENERATE, PRD_REVISE, CODE_GENERATE
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model BlueprintVersion {
  id          String   @id @default(uuid())
  blueprintId String
  userId      String
  version     Int
  name        String
  content     String
  source      String   @default("MANUAL") // GENERATE, MANUAL_EDIT, AI_REVISE, RESTORE
  createdAt   DateTime @default(now())

  blueprint Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@unique([blueprintId, version])
  @@index([blueprintId, createdAt])
  @@index([userId, createdAt])
}

model CodeProject {
  id           String   @id @default(uuid())
  userId       String
  name         String
  filesJson    String
  messagesJson String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  targetType String?
  targetId   String?
  metadata   String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model AiRequestLog {
  id         String   @id @default(uuid())
  userId     String?
  type       String
  provider   String?
  model      String?
  status     String
  durationMs Int?
  error      String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([status, createdAt])
}
